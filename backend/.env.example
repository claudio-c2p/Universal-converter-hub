# Porta em que o servidor Express vai escutar
PORT=4000

# URL do frontend, usada para configurar o CORS (em produção, aponte para o domínio da Vercel)
FRONTEND_URL=http://localhost:3000

# Diretório para arquivos temporários (PDFs, DOCX intermediários, etc.)
# Em Render/Railway normalmente /tmp já funciona como fallback.
TMP_DIR=/tmp

# Caminhos de binários de sistema usados pelas novas ferramentas (deixe em branco
# para usar o que estiver no PATH do container/servidor — ver Dockerfile).
QPDF_PATH=
GHOSTSCRIPT_PATH=
TESSERACT_PATH=
SOFFICE_PATH=
EBOOK_CONVERT_PATH=
PANDOC_PATH=
PDFLATEX_PATH=
FFMPEG_PATH=
MDB_TABLES_PATH=
MDB_EXPORT_PATH=

# ── Anexo v3 (1/3): e-mail de resultado + captcha ──
# URL pública do backend (usada para montar o link de download em e-mails de arquivo grande)
PUBLIC_BASE_URL=http://localhost:4000
# Chave da API do provedor de e-mail (ex.: Resend). Se vazio, a rota /api/send-email retorna erro 422.
EMAIL_PROVIDER_API_KEY=
# Secret do hCaptcha usado para validar o captcha antes de enviar e-mail.
HCAPTCHA_SECRET=

# ── Anexo v3 (2/3-3/3): ffmpeg, puppeteer e API keys ──
# Caminho do binário ffprobe (normalmente ao lado do ffmpeg — usado para checar
# duração/metadados de vídeo antes de processar). Deixe em branco para usar o PATH.
FFPROBE_PATH=
# Sal usado no hash HMAC das API keys (troque em produção — ver routes/apiKeys.js).
API_KEY_SALT=
