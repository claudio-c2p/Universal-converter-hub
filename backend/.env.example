# Porta em que o servidor Express vai escutar
PORT=4000

# URL do frontend, usada para configurar o CORS (em produção, aponte para o domínio da Vercel)
FRONTEND_URL=http://localhost:3000

# Diretório para arquivos temporários (PDFs, DOCX intermediários, etc.)
# Em Render/Railway normalmente /tmp já funciona como fallback.
TMP_DIR=/tmp

# Caminhos de binários de sistema usados pelas novas ferramentas (deixe em branco
# para usar o que estiver no PATH do container/servidor — ver Dockerfile).
QPDF_PATH=
GHOSTSCRIPT_PATH=
TESSERACT_PATH=
SOFFICE_PATH=
EBOOK_CONVERT_PATH=
PANDOC_PATH=
PDFLATEX_PATH=
FFMPEG_PATH=
MDB_TABLES_PATH=
MDB_EXPORT_PATH=
